# Configuración de Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=tu_clave_secreta_aqui_cambiala

# Configuración de la Base de Datos SQLite (por defecto)
# Para usar MySQL, cambia USE_SQLITE=False y configura MySQL abajo
USE_SQLITE=True
DB_PATH=database/pavimentos.db

# Configuración MySQL (opcional)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=detectar_vaches

# Configuración del modelo
MODEL_PATH=models/cnn_pavimento.keras
UPLOAD_FOLDER=static/uploads
# 500 MB para permitir subir 100 imágenes a la vez
MAX_CONTENT_LENGTH=524288000
